<idea-plugin>
  <idea-version since-build="261.25134" />
  <version>1.0.0</version>
  <id>com.example.ai-code-assistant</id>
  <name>Hello Plugin</name>
  <vendor>YourName</vendor>
  <description><![CDATA[My first IntelliJ plugin]]></description>
  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.example.helloplugin.AiSettings" />
    <applicationConfigurable parentId="tools" instance="com.example.helloplugin.AiSettingsConfigurable" id="com.example.helloplugin.AiSettingsConfigurable" displayName="AI Code Assistant" />
    <!-- Runs once on first project open to trigger onboarding -->
    <projectActivity implementation="com.example.helloplugin.PostInstallActivity" />
  </extensions>
  <actions>
    <group id="AiAssistantGroup">
      <action id="AskAiAction" class="com.example.helloplugin.AskAiAction" text="Ask AI" description="Ask AI to explain the selected code" />
      <action id="SwitchProviderAction" class="com.example.helloplugin.SwitchProviderAction" text="Switch AI Provider…" description="Change AI provider or API key" />
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
    </group>
  </actions>
</idea-plugin>
